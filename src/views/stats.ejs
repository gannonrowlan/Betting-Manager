<%- include('partials/header') %>
<section class="stats-shell stats-shell-upgraded">
  <div data-stats-content>
    <%- include('partials/statsContent') %>
  </div>
</section>

<script>
  (() => {
    const statsRoot = document.querySelector('[data-stats-content]');

    if (!statsRoot) {
      return;
    }

    let activeRequestId = 0;

    const buildPartialUrl = (inputUrl) => {
      const url = new URL(inputUrl, window.location.origin);
      url.searchParams.set('partial', '1');
      return url;
    };

    const syncBrowserUrl = (inputUrl, replaceState = false) => {
      const url = new URL(inputUrl, window.location.origin);
      url.searchParams.delete('partial');
      const method = replaceState ? 'replaceState' : 'pushState';
      window.history[method]({}, '', `${url.pathname}${url.search}${url.hash}`);
    };

    const hydrateStatsContent = () => {
      const rangeSelect = statsRoot.querySelector('select[name="range"]');
      const customDateInputs = Array.from(statsRoot.querySelectorAll('input[name="startDate"], input[name="endDate"]'));
      const filterDetails = statsRoot.querySelector('.stats-filter-details');
      const filterToggleLabel = statsRoot.querySelector('[data-stats-filter-toggle-label]');
      const filterOpenInputs = Array.from(statsRoot.querySelectorAll('[data-stats-filters-open-input]'));
      const stageOrder = ['main', 'edges', 'deep-dive'];
      const stageCaptionMap = {
        main: 'Core numbers for the current window.',
        edges: 'Compare your strongest and weakest categories side by side.',
        'deep-dive': 'Monthly performance and bankroll context that add the most signal.',
      };

      const syncCustomDateState = () => {
        if (!rangeSelect) return;

        const isCustom = rangeSelect.value === 'custom';
        customDateInputs.forEach((input) => {
          input.disabled = !isCustom;
        });

        if (filterDetails && isCustom && !filterDetails.open) {
          filterDetails.open = true;
        }
      };

      if (filterDetails && filterToggleLabel) {
        const syncFilterLabel = () => {
          filterToggleLabel.textContent = filterDetails.open ? 'Hide Filters' : 'Show Filters';
          filterOpenInputs.forEach((input) => {
            input.value = filterDetails.open ? '1' : '0';
          });
        };

        filterDetails.addEventListener('toggle', syncFilterLabel);
        syncFilterLabel();
      };

      if (rangeSelect) {
        rangeSelect.addEventListener('change', syncCustomDateState);
        syncCustomDateState();
      }

      const stageRoot = statsRoot.querySelector('[data-stats-stage]');
      const stageCaption = statsRoot.querySelector('[data-stats-stage-caption]');
      const stageTriggers = Array.from(statsRoot.querySelectorAll('[data-stats-stage-trigger]'));
      const stagePanels = Array.from(statsRoot.querySelectorAll('[data-stats-stage-panel]'));
      const stageArrows = Array.from(statsRoot.querySelectorAll('[data-stats-stage-arrow]'));
      let activeStage = stageOrder[0];

      if (stageRoot && stageTriggers.length && stagePanels.length) {
        const setActiveStage = (key) => {
          if (!stageOrder.includes(key)) return;
          activeStage = key;

          stageTriggers.forEach((trigger) => {
            const isActive = trigger.dataset.statsStageTrigger === key;
            trigger.classList.toggle('is-active', isActive);
            trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          stagePanels.forEach((panel) => {
            panel.hidden = panel.dataset.statsStagePanel !== key;
          });

          if (stageCaption) {
            stageCaption.textContent = stageCaptionMap[key] || '';
          }
        };

        const moveStage = (direction) => {
          const currentIndex = stageOrder.indexOf(activeStage);
          const nextIndex = (currentIndex + direction + stageOrder.length) % stageOrder.length;
          setActiveStage(stageOrder[nextIndex]);
        };

        stageTriggers.forEach((trigger) => {
          trigger.addEventListener('click', () => setActiveStage(trigger.dataset.statsStageTrigger));
        });

        stageArrows.forEach((arrow) => {
          arrow.addEventListener('click', () => {
            moveStage(arrow.dataset.statsStageArrow === 'next' ? 1 : -1);
          });
        });

        setActiveStage(activeStage);
      }

      statsRoot.querySelectorAll('[data-stats-async-form]').forEach((asyncForm) => {
        asyncForm.addEventListener('submit', (event) => {
          event.preventDefault();
          const action = asyncForm.getAttribute('action') || window.location.pathname;
          const formUrl = new URL(action, window.location.origin);
          const formData = new FormData(asyncForm);
          const params = new URLSearchParams();

          for (const [key, value] of formData.entries()) {
            if (value !== '') {
              params.set(key, value);
            }
          }

          formUrl.search = params.toString();
          loadStatsContent(formUrl.toString());
        });
      });

      statsRoot.querySelectorAll('[data-stats-async-link]').forEach((link) => {
        link.addEventListener('click', (event) => {
          const href = link.getAttribute('href');
          const isModifiedClick = event.metaKey || event.ctrlKey || event.shiftKey || event.altKey;

          if (!href || isModifiedClick || link.getAttribute('aria-disabled') === 'true') {
            return;
          }

          event.preventDefault();
          loadStatsContent(href);
        });
      });
    };

    const loadStatsContent = async (inputUrl, options = {}) => {
      const { replaceState = false } = options;
      const requestId = ++activeRequestId;
      const partialUrl = buildPartialUrl(inputUrl);

      statsRoot.classList.add('stats-loading');

      try {
        const response = await fetch(partialUrl.toString(), {
          headers: {
            'X-Requested-With': 'fetch',
          },
        });

        if (!response.ok) {
          throw new Error('Stats request failed');
        }

        const html = await response.text();

        if (requestId !== activeRequestId) {
          return;
        }

        statsRoot.innerHTML = html;
        hydrateStatsContent();
        syncBrowserUrl(inputUrl, replaceState);
      } catch (error) {
        window.location.assign(inputUrl);
      } finally {
        statsRoot.classList.remove('stats-loading');
      }
    };

    window.addEventListener('popstate', () => {
      loadStatsContent(window.location.href, { replaceState: true });
    });

    hydrateStatsContent();
  })();
</script>
<%- include('partials/footer') %>
