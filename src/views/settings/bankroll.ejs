<%- include('../partials/header') %>
<section class="bankroll-shell bankroll-shell-redesign">
  <section class="card bankroll-hero-card">
    <div class="bankroll-hero-copy">
      <p class="eyebrow">Bankroll Desk</p>
      <h1>Keep the bankroll page focused on the numbers that matter.</h1>
      <p class="muted">Set your bankroll baseline, update unit size, log cash movements, and review the adjustment history.</p>
    </div>

    <div class="bankroll-signal-grid">
      <article class="bankroll-signal-card bankroll-signal-card-primary">
        <span>Current bankroll</span>
        <strong class="<%= Number(summary.currentBankroll.replace(/,/g, '')) >= 0 ? 'positive' : 'negative' %>">$<%= summary.currentBankroll %></strong>
      </article>
      <article class="bankroll-signal-card">
        <span>Starting bankroll</span>
        <strong>$<%= summary.startingBankroll %></strong>
      </article>
      <article class="bankroll-signal-card">
        <span>Unit size</span>
        <strong>$<%= profile.unitSize.toFixed(2) %></strong>
      </article>
      <article class="bankroll-signal-card">
        <span>Net betting P/L</span>
        <strong class="<%= Number(summary.netProfit.replace(/,/g, '')) >= 0 ? 'positive' : 'negative' %>">
          <%= Number(summary.netProfit.replace(/,/g, '')) >= 0 ? '+' : '-' %>$<%= Math.abs(Number(summary.netProfit.replace(/,/g, ''))).toFixed(2) %>
        </strong>
      </article>
    </div>
  </section>

  <section class="bankroll-workspace-grid">
    <article class="card bankroll-work-card">
      <div class="bankroll-card-head">
        <div>
          <p class="bankroll-card-kicker">Settings</p>
          <h2>Core bankroll setup</h2>
        </div>
        <span>Only the base numbers you need to maintain.</span>
      </div>

      <form method="POST" action="/settings/bankroll" class="form-grid two-col">
        <label>
          Starting Bankroll ($)
          <input type="number" step="0.01" min="0" name="startingBankroll" value="<%= profile.startingBankroll.toFixed(2) %>" required />
        </label>

        <label>
          Unit Size ($)
          <input type="number" step="0.01" min="0.01" name="unitSize" value="<%= profile.unitSize.toFixed(2) %>" required />
        </label>

        <button class="btn full" type="submit">Save Bankroll Settings</button>
      </form>
    </article>

    <article class="card bankroll-work-card bankroll-work-card-accent">
      <div class="bankroll-card-head">
        <div>
          <p class="bankroll-card-kicker">Adjustments</p>
          <h2>Log cash movement</h2>
        </div>
        <span>Use this only for deposits and withdrawals outside of bets.</span>
      </div>

      <form method="POST" action="/settings/bankroll/transactions" class="form-grid two-col">
        <label>
          Type
          <select name="transactionType" required>
            <option value="deposit" <%= transactionForm.transactionType === 'deposit' ? 'selected' : '' %>>Deposit</option>
            <option value="withdrawal" <%= transactionForm.transactionType === 'withdrawal' ? 'selected' : '' %>>Withdrawal</option>
          </select>
        </label>

        <label>
          Amount ($)
          <input type="number" step="0.01" min="0.01" name="amount" value="<%= transactionForm.amount %>" required />
        </label>

        <label>
          Date
          <input type="date" name="transactionDate" value="<%= transactionForm.transactionDate %>" required />
        </label>

        <label>
          Notes
          <input type="text" name="notes" value="<%= transactionForm.notes %>" placeholder="Optional note" />
        </label>

        <button class="btn full" type="submit">Save Adjustment</button>
      </form>
    </article>
  </section>

  <section class="card bankroll-log-card">
    <div class="bankroll-card-head bankroll-card-head-log">
      <div>
        <p class="bankroll-card-kicker">History</p>
        <h2>Adjustment log</h2>
      </div>
      <span><%= transactions.length %> recorded movement<%= transactions.length === 1 ? '' : 's' %></span>
    </div>

    <% if (!transactions.length) { %>
      <div class="bankroll-empty-state">
        <p class="muted">No deposits or withdrawals yet. When you add one, it will appear here.</p>
      </div>
    <% } else { %>
      <div class="table-wrap bankroll-log-table-wrap">
        <table class="bankroll-log-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Amount</th>
              <th>Notes</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach((transaction) => { %>
              <tr>
                <td><%= new Date(transaction.transactionDate).toISOString().slice(0, 10) %></td>
                <td>
                  <span class="bankroll-type-pill bankroll-type-pill-<%= transaction.transactionType %>">
                    <%= transaction.transactionType === 'deposit' ? 'Deposit' : 'Withdrawal' %>
                  </span>
                </td>
                <td class="<%= transaction.transactionType === 'deposit' ? 'positive' : 'negative' %>">
                  <%= transaction.transactionType === 'deposit' ? '+' : '-' %>$<%= Number(transaction.amount).toFixed(2) %>
                </td>
                <td><%= transaction.notes || '-' %></td>
                <td>
                  <form method="POST" action="/settings/bankroll/transactions/<%= transaction.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this bankroll adjustment?');">
                    <button type="submit" class="bankroll-delete-btn">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</section>
<%- include('../partials/footer') %>
