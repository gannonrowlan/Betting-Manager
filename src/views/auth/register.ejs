<%- include('../partials/header') %>
<section class="auth-shell">
  <aside class="auth-sidecard auth-sidecard-dark">
    <p class="eyebrow">Create your account</p>
    <h1>Start building a betting record you can trust.</h1>
    <p class="auth-side-lead">Set up your account and turn your next wager into the start of a cleaner, more disciplined review process.</p>
    <div class="auth-side-list">
      <div class="auth-side-item">
        <strong>Track every bet</strong>
        <span>Keep odds, stake size, and notes in one ledger.</span>
      </div>
      <div class="auth-side-item">
        <strong>Measure performance</strong>
        <span>See ROI, win rate, and profit without a spreadsheet.</span>
      </div>
      <div class="auth-side-item">
        <strong>Manage bankroll</strong>
        <span>Review your trend with clearer context over time.</span>
      </div>
    </div>
  </aside>

  <section class="card auth-card auth-card-premium">
    <p class="eyebrow">Register</p>
    <h2>Create your account</h2>
    <p class="muted auth-intro">A few details and you are ready to start logging bets and reviewing results.</p>
    <form method="POST" action="/auth/register" class="form-grid auth-form" autocomplete="on" data-auth-form="register">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        <span>Name</span>
        <input type="text" name="name" required autocomplete="name" autofocus value="<%= formData?.name || '' %>" data-field="name" />
        <small class="field-error" data-error-for="name" aria-live="polite"></small>
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="email" required autocomplete="email" value="<%= formData?.email || '' %>" data-field="email" />
        <small class="field-error" data-error-for="email" aria-live="polite"></small>
      </label>
      <label>
        <span>Password</span>
        <div class="password-input-wrap">
          <input id="register-password" type="password" name="password" required minlength="10" autocomplete="new-password" data-field="password" />
          <button type="button" class="link-btn password-toggle" data-password-toggle="register-password" aria-label="Show password">Show</button>
        </div>
        <small class="field-hint">Use 10+ characters. Avoid your name, email, and common passwords.</small>
        <small class="field-error" data-error-for="password" aria-live="polite"></small>
      </label>
      <label>
        <span>Confirm password</span>
        <div class="password-input-wrap">
          <input id="register-confirm-password" type="password" name="confirmPassword" required minlength="10" autocomplete="new-password" data-field="confirmPassword" />
          <button type="button" class="link-btn password-toggle" data-password-toggle="register-confirm-password" aria-label="Show password">Show</button>
        </div>
        <small class="field-error" data-error-for="confirmPassword" aria-live="polite"></small>
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="rememberMe" <%= formData?.rememberMe !== false ? 'checked' : '' %> />
        Keep me signed in for 30 days
      </label>
      <button class="btn auth-submit" type="submit" data-submit-button data-default-label="Create Account" data-pending-label="Creating account...">Create Account</button>
    </form>
    <p class="auth-trust-note">No credit card required. Start tracking in minutes.</p>
    <p class="auth-switch">Already have an account? <a href="/auth/login">Log in</a>.</p>
  </section>
</section>
<script src="/public/js/authForms.js"></script>
<%- include('../partials/footer') %>
