<%- include('../partials/header') %>
<section class="auth-shell">
  <aside class="auth-sidecard auth-sidecard-dark">
    <p class="eyebrow">Reset access</p>
    <h1>Get back into your account without starting over.</h1>
    <p class="auth-side-lead">Enter the email tied to your account and Bankroll IQ will prepare a password reset link.</p>
    <div class="auth-side-list">
      <div class="auth-side-item">
        <strong>Private by default</strong>
        <span>The response stays the same whether an email exists or not.</span>
      </div>
      <div class="auth-side-item">
        <strong>Local-friendly flow</strong>
        <span>In development, the reset link is shown right on this page.</span>
      </div>
      <div class="auth-side-item">
        <strong>Fast recovery</strong>
        <span>Set a fresh password and get back to your dashboard.</span>
      </div>
    </div>
  </aside>

  <section class="card auth-card auth-card-premium">
    <p class="eyebrow">Forgot Password</p>
    <h2>Request a reset link</h2>
    <p class="muted auth-intro">Use the same email you registered with.</p>
    <form method="POST" action="/auth/forgot-password" class="form-grid auth-form" autocomplete="on" data-auth-form="forgot-password">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        <span>Email</span>
        <input type="email" name="email" required autocomplete="email" autofocus value="<%= formData?.email || '' %>" data-field="email" />
        <small class="field-error" data-error-for="email" aria-live="polite"></small>
      </label>
      <button class="btn auth-submit" type="submit" data-submit-button data-default-label="Send Reset Link" data-pending-label="Preparing link...">Send Reset Link</button>
    </form>

    <% if (devResetLink) { %>
      <div class="card" style="margin-top: 1rem;">
        <p class="eyebrow">Development Reset Link</p>
        <p class="muted">This appears locally so you can finish the flow before email delivery is set up.</p>
        <p><a href="<%= devResetLink %>"><%= devResetLink %></a></p>
      </div>
    <% } %>

    <p class="auth-switch">Remembered it after all? <a href="/auth/login">Back to login</a>.</p>
  </section>
</section>
<script src="/public/js/authForms.js"></script>
<%- include('../partials/footer') %>
