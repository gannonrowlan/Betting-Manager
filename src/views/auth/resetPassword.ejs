<%- include('../partials/header') %>
<section class="auth-shell">
  <aside class="auth-sidecard auth-sidecard-dark">
    <p class="eyebrow">Choose a new password</p>
    <h1>Reset your account access and keep your tracking history intact.</h1>
    <p class="auth-side-lead">Create a strong password that is easy for you to manage and hard for anyone else to guess.</p>
    <div class="auth-side-list">
      <div class="auth-side-item">
        <strong>10+ characters</strong>
        <span>Use enough length to make reuse and guessing harder.</span>
      </div>
      <div class="auth-side-item">
        <strong>Avoid personal info</strong>
        <span>Do not include your name or email address.</span>
      </div>
      <div class="auth-side-item">
        <strong>One-time link</strong>
        <span>Reset links expire and cannot be reused after success.</span>
      </div>
    </div>
  </aside>

  <section class="card auth-card auth-card-premium">
    <p class="eyebrow">Reset Password</p>
    <h2>Create a new password</h2>
    <p class="muted auth-intro">Once saved, use the new password the next time you log in.</p>
    <form method="POST" action="/auth/reset-password" class="form-grid auth-form" autocomplete="on" data-auth-form="reset-password">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="token" value="<%= token %>" />
      <label>
        <span>New password</span>
        <div class="password-input-wrap">
          <input id="reset-password" type="password" name="password" required minlength="10" autocomplete="new-password" data-field="password" />
          <button type="button" class="link-btn password-toggle" data-password-toggle="reset-password" aria-label="Show password">Show</button>
        </div>
        <small class="field-hint">Use 10+ characters and avoid common passwords.</small>
        <small class="field-error" data-error-for="password" aria-live="polite"></small>
      </label>
      <label>
        <span>Confirm new password</span>
        <div class="password-input-wrap">
          <input id="reset-confirm-password" type="password" name="confirmPassword" required minlength="10" autocomplete="new-password" data-field="confirmPassword" />
          <button type="button" class="link-btn password-toggle" data-password-toggle="reset-confirm-password" aria-label="Show password">Show</button>
        </div>
        <small class="field-error" data-error-for="confirmPassword" aria-live="polite"></small>
      </label>
      <button class="btn auth-submit" type="submit" data-submit-button data-default-label="Reset Password" data-pending-label="Saving password...">Reset Password</button>
    </form>
    <p class="auth-switch">Need a fresh link? <a href="/auth/forgot-password">Request another reset</a>.</p>
  </section>
</section>
<script src="/public/js/authForms.js"></script>
<%- include('../partials/footer') %>
