      </div>

      <div class="activity-card">
        <div class="preview-subheader">
          <strong>Recent bets</strong>
          <span>Last 3 graded</span>
        </div>
        <ul class="activity-list">
          <li>
            <div>
              <strong>NBA - Spread</strong>
              <span>Celtics -4.5 - 1.0u</span>
            </div>
            <b class="positive">+0.91u</b>
