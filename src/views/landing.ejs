<%- include('partials/header') %>
<div class="landing-page">
  <section class="hero hero-split hero-premium">
    <div class="hero-copy">
      <p class="eyebrow">Bet tracking + bankroll analysis for serious bettors</p>
      <h1>Track every wager with clarity.</h1>
      <p class="hero-lead">Bankroll IQ keeps your bets, bankroll, and ROI in one place so you can review performance quickly and make better staking decisions.</p>

      <div class="hero-proof-row" aria-label="What users can review inside Bankroll IQ">
        <div class="proof-pill">
          <strong>Track results</strong>
          <span>Know your profit, ROI, and record.</span>
        </div>
        <div class="proof-pill">
          <strong>Review bankroll</strong>
          <span>See how unit sizing impacts swings.</span>
        </div>
        <div class="proof-pill">
          <strong>Find patterns</strong>
          <span>Break performance down by angle.</span>
        </div>
      </div>

      <div class="hero-support-grid" aria-label="What Bankroll IQ helps you review">
        <div class="hero-support-card">
          <span class="section-label">What you can do</span>
          <strong>Log bets, monitor bankroll, and review ROI without a spreadsheet.</strong>
          <p>Everything important stays in one place, so your next decision starts with data instead of memory.</p>
        </div>
        <div class="hero-support-card hero-support-list">
          <span class="section-label">What you will see</span>
          <div class="hero-support-item">
            <strong>Profit trend</strong>
            <span>Each point shows where your bankroll stood after that graded day.</span>
          </div>
          <div class="hero-support-item">
            <strong>Recent form</strong>
            <span>Quickly check whether your last stretch is steady, volatile, or slipping.</span>
          </div>
        </div>
      </div>

      <div class="hero-workflow" aria-label="How Bankroll IQ fits into your routine">
        <div class="hero-workflow-step">
          <span class="hero-workflow-number">01</span>
          <div>
            <strong>Log the bet</strong>
            <span>Save the wager while the details are still fresh.</span>
          </div>
        </div>
        <div class="hero-workflow-step">
          <span class="hero-workflow-number">02</span>
          <div>
            <strong>Grade the result</strong>
            <span>Keep the outcome tied to the original stake and odds.</span>
          </div>
        </div>
        <div class="hero-workflow-step">
          <span class="hero-workflow-number">03</span>
          <div>
            <strong>Review the trend</strong>
            <span>See what changed before the next slate starts.</span>
          </div>
        </div>
      </div>
    </div>

    <aside class="hero-panel card dashboard-preview">
      <div class="panel-heading panel-heading-premium">
        <div class="panel-title-row">
          <span class="status-dot"></span>
          <div>
            <p>Performance dashboard</p>
            <small>30-day snapshot - synced after latest graded bet</small>
          </div>
        </div>
        <span class="panel-tag">Live snapshot</span>
      </div>

      <div class="preview-section-header">
        <div>
          <span class="section-label">Portfolio overview</span>
          <strong>Current run</strong>
        </div>
        <span class="delta-pill positive">+2.1u this week</span>
      </div>

      <div class="preview-scoreboard preview-scoreboard-premium">
        <div>
          <span>Net Profit</span>
          <strong class="positive">+$1,284</strong>
          <small class="positive">Up 8.7% ROI</small>
        </div>
        <div>
          <span>Win Rate</span>
          <strong>56.6%</strong>
          <small>142-109 record</small>
        </div>
        <div>
          <span>Average Stake</span>
          <strong>1.18u</strong>
          <small>Consistent unit sizing</small>
        </div>
        <div>
          <span>Drawdown</span>
          <strong class="negative">-3.4u</strong>
          <small>Contained risk</small>
        </div>
      </div>

      <div class="preview-chart-card">
        <div class="preview-chart-header">
          <div>
            <span class="section-label">Bankroll curve</span>
            <strong>Daily profit trend</strong>
          </div>
        </div>
        <div class="mini-chart mini-chart-bars" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="chart-axis">
          <span>Mar 8</span>
          <span>Mar 10</span>
          <span>Mar 12</span>
          <span>Mar 14</span>
          <span>Mar 16</span>
          <span>Today</span>
        </div>
      </div>

      <div class="activity-card">
        <div class="preview-subheader">
          <strong>Recent bets</strong>
          <span>Last 3 graded</span>
        </div>
        <ul class="activity-list">
          <li>
            <div>
              <strong>NBA - Spread</strong>
              <span>Celtics -4.5 - 1.0u</span>
            </div>
            <b class="positive">+0.91u</b>
          </li>
          <li>
            <div>
              <strong>NCAAB - Total</strong>
              <span>Under 146.5 - 1.25u</span>
            </div>
            <b class="negative">-1.25u</b>
          </li>
          <li>
            <div>
              <strong>NHL - Moneyline</strong>
              <span>Rangers ML - 0.8u</span>
            </div>
            <b class="positive">+0.64u</b>
          </li>
        </ul>
      </div>
    </aside>
  </section>

  <section class="feature-grid landing-features landing-features-premium">
    <article class="card feature-card feature-card-highlight feature-card-premium">
      <div class="feature-icon" aria-hidden="true">Track</div>
      <p class="feature-kicker">Track every bet</p>
      <h3>Keep a clean ledger of your action.</h3>
      <p>Log the details once and stop rebuilding your history later.</p>
      <ul class="feature-list checked-list">
        <li>Odds, stake, and notes in one place</li>
        <li>Fast entry for daily use</li>
      </ul>
    </article>
    <article class="card feature-card feature-card-highlight feature-card-premium">
      <div class="feature-icon" aria-hidden="true">Review</div>
      <p class="feature-kicker">Measure performance</p>
      <h3>See what is working and what is not.</h3>
      <p>Review profit, ROI, and record without digging through spreadsheets.</p>
      <ul class="feature-list checked-list">
        <li>Break down results by market</li>
        <li>Spot stronger and weaker angles</li>
      </ul>
    </article>
    <article class="card feature-card feature-card-highlight feature-card-premium">
      <div class="feature-icon" aria-hidden="true">Manage</div>
      <p class="feature-kicker">Manage bankroll</p>
      <h3>Stay disciplined through swings.</h3>
      <p>Keep unit sizing, drawdowns, and recent form visible before the next slate.</p>
      <ul class="feature-list checked-list">
        <li>Monitor drawdowns quickly</li>
        <li>Keep stake sizing accountable</li>
      </ul>
    </article>
  </section>

  <section class="card cta-banner cta-banner-premium">
    <div>
      <p class="eyebrow">Start tracking today</p>
      <h2>Build a record you can actually use.</h2>
      <p>Set your bankroll, log your first bet, and start reviewing your results in under 2 minutes.</p>
    </div>
    <div class="cta-actions cta-actions-premium">
      <a class="btn" href="/auth/register">Create Free Account</a>
      <a class="btn btn-secondary" href="/auth/login">Log In</a>
      <span class="cta-note">Start tracking in minutes.</span>
    </div>
  </section>
</div>
<%- include('partials/footer') %>
