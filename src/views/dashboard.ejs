<%- include('partials/header') %>
<section class="dashboard-shell dashboard-shell-upgraded">
  <section class="card dashboard-hero dashboard-hero-banner">
    <div class="dashboard-hero-banner-top">
      <div class="dashboard-hero-banner-copy">
        <p class="eyebrow">Performance Dashboard</p>
        <h1>Your betting command center.</h1>
        <p class="dashboard-banner-lead">Keep the key numbers visible at all times, then rotate through focused views when you want more detail.</p>
      </div>

      <div class="dashboard-banner-actions">
        <a href="/bets/new" class="btn">Log a new bet</a>
        <a href="/bets/history" class="btn btn-secondary">Review history</a>
      </div>
    </div>

    <div class="dashboard-essentials-grid">
      <article class="dashboard-essential-card dashboard-essential-card-primary">
        <span class="section-label">Current window</span>
        <strong class="<%= stats.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= stats.netProfit.toFixed(2) %></strong>
        <span><%= stats.totalBets %> bets tracked in this view</span>
      </article>
      <article class="dashboard-essential-card">
        <span class="section-label">ROI</span>
        <strong class="<%= Number(stats.roi) >= 0 ? 'positive' : 'negative' %>"><%= stats.roi %>%</strong>
        <span><%= stats.units %>u overall in this window</span>
      </article>
      <article class="dashboard-essential-card">
        <span class="section-label">Record</span>
        <strong><%= stats.wins %>-<%= stats.losses %>-<%= stats.pushes %></strong>
        <span><%= stats.winRate %>% win rate</span>
      </article>
      <article class="dashboard-essential-card">
        <span class="section-label">Bankroll</span>
        <strong class="<%= stats.currentBankroll >= stats.startingBankroll ? 'positive' : 'negative' %>">$<%= stats.currentBankroll.toFixed(2) %></strong>
        <span><%= stats.bankrollRoi %>% vs starting bankroll</span>
      </article>
      <article class="dashboard-essential-card">
        <span class="section-label">Average Stake</span>
        <strong>$<%= stats.averageStake.toFixed(2) %></strong>
        <span>Unit size: $<%= stats.unitSize.toFixed(2) %></span>
      </article>
      <article class="dashboard-essential-card">
        <span class="section-label">Current Streak</span>
        <strong><%= stats.currentStreak.label %></strong>
        <span>Recent form at a glance</span>
      </article>
    </div>
  </section>

  <section class="dashboard-stage dashboard-stage-priority card" data-dashboard-stage>
    <div class="dashboard-stage-bar">
      <div class="dashboard-stage-bar-copy">
        <span class="section-label">Switching Views</span>
        <strong>Move through the dashboard without scrolling the whole page</strong>
        <small>Currently viewing: <%= filterLabel %></small>
      </div>

      <div class="dashboard-stage-bar-actions">
        <button type="button" class="dashboard-stage-arrow" data-stage-arrow="prev" aria-label="Previous dashboard view">Prev</button>
        <div class="dashboard-stage-nav dashboard-stage-nav-upgraded" role="tablist" aria-label="Dashboard views">
          <button type="button" class="dashboard-stage-pill is-active" data-stage-trigger="snapshot" role="tab" aria-selected="true">Snapshot</button>
          <button type="button" class="dashboard-stage-pill" data-stage-trigger="trend" role="tab" aria-selected="false">Trend</button>
          <button type="button" class="dashboard-stage-pill" data-stage-trigger="recent" role="tab" aria-selected="false">Recent Bets</button>
          <button type="button" class="dashboard-stage-pill" data-stage-trigger="insights" role="tab" aria-selected="false">Insights</button>
        </div>
        <button type="button" class="dashboard-stage-arrow" data-stage-arrow="next" aria-label="Next dashboard view">Next</button>
      </div>
    </div>

    <section class="dashboard-stage-panel dashboard-stage-panel-snapshot hero-panel card" data-stage-panel="snapshot">
      <div class="panel-heading panel-heading-premium">
        <div class="panel-title-row">
          <span class="status-dot"></span>
          <div>
            <p>Live dashboard</p>
            <small><%= filterLabel %></small>
          </div>
        </div>
        <span class="panel-tag">Always on</span>
      </div>

      <div class="dashboard-snapshot-grid">
        <section class="dashboard-snapshot-main">
          <div class="preview-scoreboard preview-scoreboard-premium dashboard-scoreboard dashboard-scoreboard-command">
            <div>
              <span>ROI</span>
              <strong class="<%= Number(stats.roi) >= 0 ? 'positive' : 'negative' %>"><%= stats.roi %>%</strong>
              <small><%= stats.units %>u in profit</small>
            </div>
            <div>
              <span>Record</span>
              <strong><%= stats.wins %>-<%= stats.losses %>-<%= stats.pushes %></strong>
              <small><%= stats.winRate %>% win rate</small>
            </div>
            <div>
              <span>Total Stake</span>
              <strong>$<%= stats.totalStake.toFixed(2) %></strong>
              <small>$<%= stats.averageStake.toFixed(2) %> average stake</small>
            </div>
            <div>
              <span>Current Streak</span>
              <strong><%= stats.currentStreak.label %></strong>
              <small>Recent form at a glance</small>
            </div>
          </div>

          <div class="dashboard-snapshot-story">
            <article class="dashboard-story-card">
              <span class="section-label">Window read</span>
              <strong class="<%= stats.netProfit >= 0 ? 'positive' : 'negative' %>"><%= stats.netProfit >= 0 ? 'Positive momentum' : 'Pressure window' %></strong>
              <p><%= stats.netProfit >= 0 ? `You're ahead by $${stats.netProfit.toFixed(2)} with bankroll still in healthy shape.` : `You're down $${Math.abs(stats.netProfit).toFixed(2)} in this view, so this is the right time to review angle quality and sizing.` %></p>
            </article>
            <article class="dashboard-story-card">
              <span class="section-label">Bankroll status</span>
              <strong>$<%= stats.currentBankroll.toFixed(2) %></strong>
              <p>Started at $<%= stats.startingBankroll.toFixed(2) %>. Unit size is currently set at $<%= stats.unitSize.toFixed(2) %>.</p>
            </article>
          </div>
        </section>

        <aside class="dashboard-snapshot-side">
          <article class="dashboard-side-signal">
            <span>Best sport</span>
            <strong><%= highlights.bestSport ? highlights.bestSport.key : 'No trend yet' %></strong>
            <small><%= highlights.bestSport ? `${highlights.bestSport.roi}% ROI across ${highlights.bestSport.totalBets} bets` : 'More graded bets will surface a leader.' %></small>
          </article>
          <article class="dashboard-side-signal">
            <span>Toughest sport</span>
            <strong><%= highlights.toughestSport ? highlights.toughestSport.key : 'No trend yet' %></strong>
            <small><%= highlights.toughestSport ? `${highlights.toughestSport.roi}% ROI in this window` : 'No weak spot identified yet.' %></small>
          </article>
          <article class="dashboard-side-signal">
            <span>Best sportsbook</span>
            <strong><%= highlights.bestSportsbook ? highlights.bestSportsbook.key : 'No trend yet' %></strong>
            <small><%= highlights.bestSportsbook ? `${highlights.bestSportsbook.units}u in this view` : 'Add sportsbook data to compare books.' %></small>
          </article>
          <article class="dashboard-side-signal">
            <span>Window label</span>
            <strong><%= filterLabel %></strong>
            <small>Use the trend view when you want to adjust the date range.</small>
          </article>
        </aside>
      </div>
    </section>

    <section class="dashboard-stage-panel card dashboard-stage-panel-trend" data-stage-panel="trend" hidden>
      <div class="dashboard-panel-shell">
        <div class="dashboard-panel-topline">
          <div class="preview-section-header">
            <div>
              <span class="section-label">Bankroll trend</span>
              <strong>Daily performance in this window</strong>
            </div>
            <span class="delta-pill <%= stats.netProfit >= 0 ? 'positive' : 'negative' %>"><%= stats.netProfit >= 0 ? '+' : '' %><%= stats.units %>u</span>
          </div>

          <details class="dashboard-inline-filter">
            <summary class="dashboard-inline-filter-toggle">Adjust window</summary>
            <form method="GET" action="/dashboard" class="form-grid dashboard-filter-grid">
              <label>
                Range
                <select name="range">
                  <option value="7d" <%= filters.range === '7d' ? 'selected' : '' %>>Last 7 days</option>
                  <option value="30d" <%= filters.range === '30d' ? 'selected' : '' %>>Last 30 days</option>
                  <option value="90d" <%= filters.range === '90d' ? 'selected' : '' %>>Last 90 days</option>
                  <option value="month" <%= filters.range === 'month' ? 'selected' : '' %>>This month</option>
                  <option value="all" <%= filters.range === 'all' ? 'selected' : '' %>>All time</option>
                  <option value="custom" <%= filters.range === 'custom' ? 'selected' : '' %>>Custom range</option>
                </select>
              </label>
              <label>
                Start Date
                <input type="date" name="startDate" value="<%= filters.startDateValue %>" <%= filters.isCustom ? '' : 'disabled' %>>
              </label>
              <label>
                End Date
                <input type="date" name="endDate" value="<%= filters.endDateValue %>" <%= filters.isCustom ? '' : 'disabled' %>>
              </label>
              <div class="filter-actions">
                <button type="submit" class="btn btn-small">Apply</button>
                <a href="/dashboard" class="btn btn-secondary btn-small">Reset</a>
              </div>
            </form>
          </details>
        </div>

        <% if (!trendSeries.length) { %>
          <div class="dashboard-empty-state">
            <p class="muted">Add graded bets to see your trend build over time.</p>
            <a href="/bets/new" class="btn btn-small">Log your first bet</a>
          </div>
        <% } else { %>
          <div class="dashboard-trend-summary">
            <article class="dashboard-trend-metric">
              <span>Window change</span>
              <strong class="<%= trendInsights.windowChange.dayProfit >= 0 ? 'positive' : 'negative' %>">$<%= trendInsights.windowChange.dayProfit.toFixed(2) %></strong>
              <small><%= trendInsights.windowChange.label %></small>
            </article>
            <article class="dashboard-trend-metric">
              <span>Best day</span>
              <strong class="<%= trendInsights.bestDay.dayProfit >= 0 ? 'positive' : 'negative' %>">$<%= trendInsights.bestDay.dayProfit.toFixed(2) %></strong>
              <small><%= trendInsights.bestDay.label %></small>
            </article>
            <article class="dashboard-trend-metric">
              <span>Worst day</span>
              <strong class="<%= trendInsights.worstDay.dayProfit >= 0 ? 'positive' : 'negative' %>">$<%= trendInsights.worstDay.dayProfit.toFixed(2) %></strong>
              <small><%= trendInsights.worstDay.label %></small>
            </article>
          </div>
          <div class="dashboard-trend-chart" data-trend-chart data-points='<%- JSON.stringify(trendSeries) %>' aria-label="Bankroll trend bar chart"></div>
        <% } %>
      </div>
    </section>

    <section class="dashboard-stage-panel card dashboard-stage-panel-recent" data-stage-panel="recent" hidden>
      <div class="dashboard-panel-shell">
        <div class="preview-subheader">
          <div>
            <strong>Recent bets</strong>
            <span>Latest <%= recentBets.length %> bets in this view</span>
          </div>
          <a href="/bets/history" class="text-link">Open full history</a>
        </div>

        <% if (!recentBets.length) { %>
          <div class="dashboard-empty-state">
            <p class="muted">No bets in this date range yet.</p>
            <a href="/bets/new" class="btn btn-small">Log a bet</a>
          </div>
        <% } else { %>
          <div class="dashboard-recent-list dashboard-recent-list-stage">
            <% recentBets.forEach((bet) => { %>
              <article class="dashboard-bet-row dashboard-bet-row-stage">
                <div class="dashboard-bet-main">
                  <strong><%= bet.sport %> - <%= bet.leg_count ? `${bet.bet_type} (${bet.leg_count} legs)` : bet.bet_type %></strong>
                  <span><%= bet.displayMarket || bet.market %></span>
                  <% if (bet.legs?.length) { %>
                    <div class="dashboard-leg-list">
                      <% bet.legs.forEach((leg, index) => { %>
                        <span><strong>Leg <%= index + 1 %>:</strong> <%= bet.isMultiSport && leg.sport ? `${leg.sport} - ` : '' %><%= leg.market %></span>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
                <div class="dashboard-bet-meta">
                  <span><%= bet.sportsbook || 'No book' %></span>
                  <span><%= new Date(bet.bet_date).toISOString().slice(0, 10) %></span>
                  <span><%= Number(bet.stake).toFixed(2) %> stake</span>
                  <span class="dashboard-result-pill dashboard-result-<%= bet.result %>"><%= bet.result %></span>
                  <strong class="<%= bet.profit_loss >= 0 ? 'positive' : 'negative' %>">$<%= Number(bet.profit_loss).toFixed(2) %></strong>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section class="dashboard-stage-panel card dashboard-stage-panel-insights" data-stage-panel="insights" hidden>
      <div class="dashboard-panel-shell">
        <div class="preview-subheader">
          <div>
            <strong>Performance insights</strong>
            <span>Best and weakest edges in the current view</span>
          </div>
        </div>

        <div class="dashboard-insight-grid">
          <article class="card insight-card dashboard-insight-card">
            <p class="eyebrow">Best Sport</p>
            <% if (!highlights.bestSport) { %>
              <p class="muted">No sport-level trends yet in this window.</p>
            <% } else { %>
              <h3><%= highlights.bestSport.key %></h3>
              <p class="insight-number <%= highlights.bestSport.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.bestSport.netProfit).toFixed(2) %></p>
              <p class="muted"><%= highlights.bestSport.totalBets %> bets | <%= highlights.bestSport.roi %>% ROI | <%= highlights.bestSport.units %>u</p>
            <% } %>
          </article>
          <article class="card insight-card dashboard-insight-card">
            <p class="eyebrow">Toughest Sport</p>
            <% if (!highlights.toughestSport) { %>
              <p class="muted">Add more bets to identify trouble spots.</p>
            <% } else { %>
              <h3><%= highlights.toughestSport.key %></h3>
              <p class="insight-number <%= highlights.toughestSport.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.toughestSport.netProfit).toFixed(2) %></p>
              <p class="muted"><%= highlights.toughestSport.totalBets %> bets | <%= highlights.toughestSport.roi %>% ROI | <%= highlights.toughestSport.units %>u</p>
            <% } %>
          </article>
          <article class="card insight-card dashboard-insight-card">
            <p class="eyebrow">Best Sportsbook</p>
            <% if (!highlights.bestSportsbook) { %>
              <p class="muted">Add sportsbook data on new bets to compare books here.</p>
            <% } else { %>
              <h3><%= highlights.bestSportsbook.key %></h3>
              <p class="insight-number <%= highlights.bestSportsbook.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.bestSportsbook.netProfit).toFixed(2) %></p>
              <p class="muted"><%= highlights.bestSportsbook.totalBets %> bets | <%= highlights.bestSportsbook.roi %>% ROI | <%= highlights.bestSportsbook.units %>u</p>
            <% } %>
          </article>
          <article class="card insight-card dashboard-insight-card">
            <p class="eyebrow">Toughest Sportsbook</p>
            <% if (!highlights.toughestSportsbook) { %>
              <p class="muted">Track a few books to spot where your value drops off.</p>
            <% } else { %>
              <h3><%= highlights.toughestSportsbook.key %></h3>
              <p class="insight-number <%= highlights.toughestSportsbook.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.toughestSportsbook.netProfit).toFixed(2) %></p>
              <p class="muted"><%= highlights.toughestSportsbook.totalBets %> bets | <%= highlights.toughestSportsbook.roi %>% ROI | <%= highlights.toughestSportsbook.units %>u</p>
            <% } %>
          </article>
        </div>
      </div>
    </section>
  </section>
</section>

<script>
  const rangeSelect = document.querySelector('select[name="range"]');
  const customDateInputs = document.querySelectorAll('input[name="startDate"], input[name="endDate"]');

  function syncCustomDateState() {
    const isCustom = rangeSelect.value === 'custom';
    customDateInputs.forEach((input) => {
      input.disabled = !isCustom;
    });
  }

  if (rangeSelect) {
    rangeSelect.addEventListener('change', syncCustomDateState);
    syncCustomDateState();
  }

  const stageOrder = ['snapshot', 'trend', 'recent', 'insights'];
  const stageTriggers = Array.from(document.querySelectorAll('[data-stage-trigger]'));
  const stagePanels = Array.from(document.querySelectorAll('[data-stage-panel]'));
  const stageArrows = Array.from(document.querySelectorAll('[data-stage-arrow]'));
  let activeStage = 'snapshot';

  if (stageTriggers.length && stagePanels.length) {
    const setActiveStage = (key) => {
      if (!stageOrder.includes(key)) return;
      activeStage = key;

      stageTriggers.forEach((trigger) => {
        const isActive = trigger.dataset.stageTrigger === key;
        trigger.classList.toggle('is-active', isActive);
        trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      stagePanels.forEach((panel) => {
        panel.hidden = panel.dataset.stagePanel !== key;
      });
    };

    const moveStage = (direction) => {
      const currentIndex = stageOrder.indexOf(activeStage);
      const nextIndex = (currentIndex + direction + stageOrder.length) % stageOrder.length;
      setActiveStage(stageOrder[nextIndex]);
    };

    stageTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => setActiveStage(trigger.dataset.stageTrigger));
    });

    stageArrows.forEach((arrow) => {
      arrow.addEventListener('click', () => {
        moveStage(arrow.dataset.stageArrow === 'next' ? 1 : -1);
      });
    });

    setActiveStage(activeStage);
  }

  document.querySelectorAll('[data-trend-chart]').forEach((chart) => {
    const points = JSON.parse(chart.getAttribute('data-points') || '[]');
    if (!points.length) return;

    const values = points.map((point) => Number(point.bankroll));
    const min = Math.min(...values);
    const max = Math.max(...values);
    const range = max - min || 1;
    const axisLabels = [
      points[0]?.label,
      points[Math.floor((points.length - 1) / 2)]?.label,
      points[points.length - 1]?.label,
    ].filter(Boolean);

    const barsMarkup = points.map((point, index) => {
      const heightPercent = (((Number(point.bankroll) - min) / range) * 62) + 24;
      const toneClass = Number(point.dayProfit) >= 0 ? 'is-positive' : 'is-negative';

      return `
        <button
          type="button"
          class="dashboard-trend-bar ${toneClass}"
          style="height:${heightPercent.toFixed(2)}%;"
          data-point-index="${index}"
          aria-label="${point.label}: bankroll $${Number(point.bankroll).toFixed(2)}, day change ${Number(point.dayProfit) >= 0 ? '+' : ''}$${Number(point.dayProfit).toFixed(2)}"
        ></button>
      `;
    }).join('');

    chart.innerHTML = `
      <div class="dashboard-chart-tooltip" hidden></div>
      <div class="dashboard-trend-bars" role="img" aria-hidden="true">
        ${barsMarkup}
      </div>
      <div class="chart-axis dashboard-chart-axis">
        ${axisLabels.map((label) => `<span>${label}</span>`).join('')}
      </div>
    `;

    const tooltip = chart.querySelector('.dashboard-chart-tooltip');
    const pointNodes = chart.querySelectorAll('[data-point-index]');

    const showTooltip = (pointIndex, target) => {
      const point = points[Number(pointIndex)];
      if (!point || !tooltip || !target) return;

      tooltip.innerHTML = `
        <strong>${point.label}</strong>
        <span>Bankroll: $${Number(point.bankroll).toFixed(2)}</span>
        <span>Net profit: $${Number(point.netProfit).toFixed(2)}</span>
        <span>Day change: ${Number(point.dayProfit) >= 0 ? '+' : ''}$${Number(point.dayProfit).toFixed(2)}</span>
      `;

      tooltip.hidden = false;
      const targetRect = target.getBoundingClientRect();
      const chartRect = chart.getBoundingClientRect();
      tooltip.style.left = `${targetRect.left - chartRect.left}px`;
      tooltip.style.top = `${targetRect.top - chartRect.top - 12}px`;
    };

    const hideTooltip = () => {
      if (tooltip) {
        tooltip.hidden = true;
      }
    };

    pointNodes.forEach((pointNode) => {
      pointNode.addEventListener('mouseenter', () => showTooltip(pointNode.dataset.pointIndex, pointNode));
      pointNode.addEventListener('focus', () => showTooltip(pointNode.dataset.pointIndex, pointNode));
      pointNode.addEventListener('mouseleave', hideTooltip);
      pointNode.addEventListener('blur', hideTooltip);
      pointNode.addEventListener('click', () => showTooltip(pointNode.dataset.pointIndex, pointNode));
    });
  });
</script>
<%- include('partials/footer') %>
