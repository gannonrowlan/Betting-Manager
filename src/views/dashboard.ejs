<%- include('partials/header') %>
<section class="dashboard-shell">
  <section class="dashboard-hero dashboard-hero-premium card">
    <div class="dashboard-hero-copy">
      <p class="eyebrow">Performance Dashboard</p>
      <h1>Review your bankroll with real context.</h1>
      <p class="muted dashboard-hero-lead"><%= performanceMessage %></p>

      <div class="hero-actions">
        <a href="/bets/new" class="btn">Log a new bet</a>
        <a href="/bets/history" class="btn btn-secondary">Review bet history</a>
      </div>

      <div class="dashboard-kpi-strip">
        <article class="dashboard-kpi-card">
          <span class="section-label">Current window</span>
          <strong class="<%= stats.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= stats.netProfit.toFixed(2) %></strong>
          <span>Net profit across <%= stats.totalBets %> bets</span>
        </article>
        <article class="dashboard-kpi-card">
          <span class="section-label">Bankroll</span>
          <strong class="<%= stats.currentBankroll >= stats.startingBankroll ? 'positive' : 'negative' %>">$<%= stats.currentBankroll.toFixed(2) %></strong>
          <span><%= stats.bankrollRoi %>% vs starting bankroll</span>
        </article>
      </div>
    </div>

    <aside class="dashboard-hero-panel card dashboard-preview dashboard-preview-live">
      <div class="panel-heading panel-heading-premium">
        <div class="panel-title-row">
          <span class="status-dot"></span>
          <div>
            <p>Current window</p>
            <small><%= filterLabel %></small>
          </div>
        </div>
        <span class="panel-tag">Live dashboard</span>
      </div>

      <div class="preview-scoreboard preview-scoreboard-premium dashboard-scoreboard">
        <div>
          <span>ROI</span>
          <strong class="<%= Number(stats.roi) >= 0 ? 'positive' : 'negative' %>"><%= stats.roi %>%</strong>
          <small><%= stats.units %>u in profit</small>
        </div>
        <div>
          <span>Record</span>
          <strong><%= stats.wins %>-<%= stats.losses %>-<%= stats.pushes %></strong>
          <small><%= stats.winRate %>% win rate</small>
        </div>
        <div>
          <span>Average Stake</span>
          <strong>$<%= stats.averageStake.toFixed(2) %></strong>
          <small>$<%= stats.unitSize.toFixed(2) %> unit size</small>
        </div>
        <div>
          <span>Current Streak</span>
          <strong><%= stats.currentStreak.label %></strong>
          <small>Recent form at a glance</small>
        </div>
      </div>
    </aside>
  </section>

  <section class="card dashboard-filter-card">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Time Window</p>
        <h2>Filter dashboard performance</h2>
        <p class="muted">Currently viewing: <strong><%= filterLabel %></strong></p>
      </div>
    </div>
    <form method="GET" action="/dashboard" class="form-grid dashboard-filter-grid">
      <label>
        Range
        <select name="range">
          <option value="7d" <%= filters.range === '7d' ? 'selected' : '' %>>Last 7 days</option>
          <option value="30d" <%= filters.range === '30d' ? 'selected' : '' %>>Last 30 days</option>
          <option value="90d" <%= filters.range === '90d' ? 'selected' : '' %>>Last 90 days</option>
          <option value="month" <%= filters.range === 'month' ? 'selected' : '' %>>This month</option>
          <option value="all" <%= filters.range === 'all' ? 'selected' : '' %>>All time</option>
          <option value="custom" <%= filters.range === 'custom' ? 'selected' : '' %>>Custom range</option>
        </select>
      </label>
      <label>
        Start Date
        <input type="date" name="startDate" value="<%= filters.startDateValue %>" <%= filters.isCustom ? '' : 'disabled' %>>
      </label>
      <label>
        End Date
        <input type="date" name="endDate" value="<%= filters.endDateValue %>" <%= filters.isCustom ? '' : 'disabled' %>>
      </label>
      <div class="filter-actions">
        <button type="submit" class="btn btn-small">Apply</button>
        <a href="/dashboard" class="btn btn-secondary btn-small">Reset</a>
      </div>
    </form>
  </section>

  <section class="dashboard-overview-grid">
    <section class="card dashboard-trend-card">
      <div class="preview-section-header">
        <div>
          <span class="section-label">Bankroll curve</span>
          <strong>Daily trend in this window</strong>
        </div>
        <span class="delta-pill <%= stats.netProfit >= 0 ? 'positive' : 'negative' %>"><%= stats.netProfit >= 0 ? '+' : '' %><%= stats.units %>u</span>
      </div>

      <% if (!trendSeries.length) { %>
        <div class="dashboard-empty-state">
          <p class="muted">Add graded bets to see your trend line build over time.</p>
          <a href="/bets/new" class="btn btn-small">Log your first bet</a>
        </div>
      <% } else { %>
        <div class="dashboard-trend-summary">
          <article class="dashboard-trend-metric">
            <span>Window change</span>
            <strong class="<%= trendInsights.windowChange.dayProfit >= 0 ? 'positive' : 'negative' %>">$<%= trendInsights.windowChange.dayProfit.toFixed(2) %></strong>
            <small><%= trendInsights.windowChange.label %></small>
          </article>
          <article class="dashboard-trend-metric">
            <span>Best day</span>
            <strong class="<%= trendInsights.bestDay.dayProfit >= 0 ? 'positive' : 'negative' %>">$<%= trendInsights.bestDay.dayProfit.toFixed(2) %></strong>
            <small><%= trendInsights.bestDay.label %></small>
          </article>
          <article class="dashboard-trend-metric">
            <span>Worst day</span>
            <strong class="<%= trendInsights.worstDay.dayProfit >= 0 ? 'positive' : 'negative' %>">$<%= trendInsights.worstDay.dayProfit.toFixed(2) %></strong>
            <small><%= trendInsights.worstDay.label %></small>
          </article>
        </div>
        <div class="dashboard-trend-chart" data-trend-chart data-points='<%- JSON.stringify(trendSeries) %>' aria-label="Bankroll trend chart"></div>
      <% } %>
    </section>

    <aside class="dashboard-side-column">
      <section class="stats-grid dashboard-stats-grid">
        <div class="card stat-card stat-card-featured">
          <h3>Net Profit</h3>
          <p class="<%= stats.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= stats.netProfit.toFixed(2) %></p>
          <small><%= stats.roi %>% ROI in this window</small>
        </div>
        <div class="card stat-card">
          <h3>Record</h3>
          <p><%= stats.wins %>-<%= stats.losses %>-<%= stats.pushes %></p>
          <small><%= stats.winRate %>% win rate</small>
        </div>
        <div class="card stat-card">
          <h3>Total Stake</h3>
          <p>$<%= stats.totalStake.toFixed(2) %></p>
          <small>$<%= stats.averageStake.toFixed(2) %> average stake</small>
        </div>
        <div class="card stat-card">
          <h3>Bankroll</h3>
          <p class="<%= stats.currentBankroll >= stats.startingBankroll ? 'positive' : 'negative' %>">$<%= stats.currentBankroll.toFixed(2) %></p>
          <small>Started at $<%= stats.startingBankroll.toFixed(2) %></small>
        </div>
      </section>

      <section class="stats-grid two-up insights-grid">
        <article class="card insight-card">
          <p class="eyebrow">Best Sport</p>
          <% if (!highlights.bestSport) { %>
            <p class="muted">No sport-level trends yet in this window.</p>
          <% } else { %>
            <h3><%= highlights.bestSport.key %></h3>
            <p class="insight-number <%= highlights.bestSport.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.bestSport.netProfit).toFixed(2) %></p>
            <p class="muted"><%= highlights.bestSport.totalBets %> bets · <%= highlights.bestSport.roi %>% ROI · <%= highlights.bestSport.units %>u</p>
          <% } %>
        </article>
        <article class="card insight-card">
          <p class="eyebrow">Toughest Sport</p>
          <% if (!highlights.toughestSport) { %>
            <p class="muted">Add more bets to identify trouble spots.</p>
          <% } else { %>
            <h3><%= highlights.toughestSport.key %></h3>
            <p class="insight-number <%= highlights.toughestSport.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.toughestSport.netProfit).toFixed(2) %></p>
            <p class="muted"><%= highlights.toughestSport.totalBets %> bets · <%= highlights.toughestSport.roi %>% ROI · <%= highlights.toughestSport.units %>u</p>
          <% } %>
        </article>
        <article class="card insight-card">
          <p class="eyebrow">Best Sportsbook</p>
          <% if (!highlights.bestSportsbook) { %>
            <p class="muted">Add sportsbook data on new bets to compare books here.</p>
          <% } else { %>
            <h3><%= highlights.bestSportsbook.key %></h3>
            <p class="insight-number <%= highlights.bestSportsbook.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.bestSportsbook.netProfit).toFixed(2) %></p>
            <p class="muted"><%= highlights.bestSportsbook.totalBets %> bets · <%= highlights.bestSportsbook.roi %>% ROI · <%= highlights.bestSportsbook.units %>u</p>
          <% } %>
        </article>
        <article class="card insight-card">
          <p class="eyebrow">Toughest Sportsbook</p>
          <% if (!highlights.toughestSportsbook) { %>
            <p class="muted">Track a few books to spot where your value drops off.</p>
          <% } else { %>
            <h3><%= highlights.toughestSportsbook.key %></h3>
            <p class="insight-number <%= highlights.toughestSportsbook.netProfit >= 0 ? 'positive' : 'negative' %>">$<%= Number(highlights.toughestSportsbook.netProfit).toFixed(2) %></p>
            <p class="muted"><%= highlights.toughestSportsbook.totalBets %> bets · <%= highlights.toughestSportsbook.roi %>% ROI · <%= highlights.toughestSportsbook.units %>u</p>
          <% } %>
        </article>
      </section>
    </aside>
  </section>

  <section class="card dashboard-recent-card">
    <div class="preview-subheader">
      <strong>Recent bets in this window</strong>
      <span>Latest <%= recentBets.length %> graded or tracked bets</span>
    </div>
    <% if (!recentBets.length) { %>
      <p class="muted">No bets in this date range. Adjust the filter or add your next wager.</p>
      <a href="/bets/new" class="btn">Add your first bet</a>
    <% } else { %>
      <div class="dashboard-recent-list">
        <% recentBets.forEach((bet) => { %>
          <article class="dashboard-bet-row">
            <div class="dashboard-bet-main">
              <strong><%= bet.sport %> - <%= bet.leg_count ? `${bet.bet_type} (${bet.leg_count} legs)` : bet.bet_type %></strong>
              <span><%= bet.displayMarket || bet.market %></span>
              <% if (bet.legs?.length) { %>
                <div class="dashboard-leg-list">
                  <% bet.legs.forEach((leg, index) => { %>
                    <span><strong>Leg <%= index + 1 %>:</strong> <%= bet.isMultiSport && leg.sport ? `${leg.sport} - ` : '' %><%= leg.market %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <div class="dashboard-bet-meta">
              <span><%= bet.sportsbook || 'No book' %></span>
              <span><%= new Date(bet.bet_date).toISOString().slice(0, 10) %></span>
              <span><%= Number(bet.stake).toFixed(2) %> stake</span>
              <span class="dashboard-result-pill dashboard-result-<%= bet.result %>"><%= bet.result %></span>
              <strong class="<%= bet.profit_loss >= 0 ? 'positive' : 'negative' %>">$<%= Number(bet.profit_loss).toFixed(2) %></strong>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<script>
  const rangeSelect = document.querySelector('select[name="range"]');
  const customDateInputs = document.querySelectorAll('input[name="startDate"], input[name="endDate"]');

  function syncCustomDateState() {
    const isCustom = rangeSelect.value === 'custom';
    customDateInputs.forEach((input) => {
      input.disabled = !isCustom;
    });
  }

  if (rangeSelect) {
    rangeSelect.addEventListener('change', syncCustomDateState);
    syncCustomDateState();
  }

  document.querySelectorAll('[data-trend-chart]').forEach((chart) => {
    const points = JSON.parse(chart.getAttribute('data-points') || '[]');
    if (!points.length) return;

    const values = points.map((point) => Number(point.bankroll));
    const min = Math.min(...values);
    const max = Math.max(...values);
    const width = 100;
    const height = 100;
    const step = points.length > 1 ? width / (points.length - 1) : width;
    const range = max - min || 1;

    const linePoints = points.map((point, index) => {
      const x = points.length > 1 ? index * step : width / 2;
      const y = height - (((Number(point.bankroll) - min) / range) * 76 + 12);
      return {
        x: x.toFixed(2),
        y: y.toFixed(2),
      };
    });

    const areaPoints = ['0,100', ...linePoints.map((point) => `${point.x},${point.y}`), `${width},100`].join(' ');
    const axisLabels = [
      points[0]?.label,
      points[Math.floor((points.length - 1) / 2)]?.label,
      points[points.length - 1]?.label,
    ].filter(Boolean);

    chart.innerHTML = `
      <div class="dashboard-chart-tooltip" hidden></div>
      <svg viewBox="0 0 100 100" role="img" aria-hidden="true" preserveAspectRatio="none">
        <polyline class="dashboard-trend-area" points="${areaPoints}"></polyline>
        <polyline class="dashboard-trend-line" points="${linePoints.map((point) => `${point.x},${point.y}`).join(' ')}"></polyline>
        ${linePoints.map((point, index) => `
          <circle
            class="dashboard-trend-point"
            cx="${point.x}"
            cy="${point.y}"
            r="2.4"
            data-point-index="${index}"
            tabindex="0"
          ></circle>
        `).join('')}
      </svg>
      <div class="chart-axis dashboard-chart-axis">
        ${axisLabels.map((label) => `<span>${label}</span>`).join('')}
      </div>
    `;

    const tooltip = chart.querySelector('.dashboard-chart-tooltip');
    const pointNodes = chart.querySelectorAll('[data-point-index]');

    const showTooltip = (pointIndex, target) => {
      const point = points[Number(pointIndex)];
      if (!point || !tooltip || !target) return;

      tooltip.innerHTML = `
        <strong>${point.label}</strong>
        <span>Bankroll: $${Number(point.bankroll).toFixed(2)}</span>
        <span>Net profit: $${Number(point.netProfit).toFixed(2)}</span>
        <span>Day change: ${Number(point.dayProfit) >= 0 ? '+' : ''}$${Number(point.dayProfit).toFixed(2)}</span>
      `;

      tooltip.hidden = false;
      const targetRect = target.getBoundingClientRect();
      const chartRect = chart.getBoundingClientRect();
      tooltip.style.left = `${targetRect.left - chartRect.left}px`;
      tooltip.style.top = `${targetRect.top - chartRect.top - 12}px`;
    };

    const hideTooltip = () => {
      if (tooltip) {
        tooltip.hidden = true;
      }
    };

    pointNodes.forEach((pointNode) => {
      pointNode.addEventListener('mouseenter', () => showTooltip(pointNode.dataset.pointIndex, pointNode));
      pointNode.addEventListener('focus', () => showTooltip(pointNode.dataset.pointIndex, pointNode));
      pointNode.addEventListener('mouseleave', hideTooltip);
      pointNode.addEventListener('blur', hideTooltip);
      pointNode.addEventListener('click', () => showTooltip(pointNode.dataset.pointIndex, pointNode));
    });
  });
</script>
<%- include('partials/footer') %>
